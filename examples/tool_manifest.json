{
  "tool_id": "demo_metadata_lookup",
  "tool_name": "Demo Metadata Lookup Tool",
  "tool_version": "0.1.0",
  "description": "Returns non-sensitive metadata fields for a named dataset.",
  "allowed_operations": [
    "metadata.lookup"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "dataset",
      "fields"
    ],
    "properties": {
      "dataset": {
        "type": "string"
      },
      "fields": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": [
      "dataset",
      "metadata"
    ],
    "properties": {
      "dataset": {
        "type": "string"
      },
      "metadata": {
        "type": "object"
      }
    }
  }
}
