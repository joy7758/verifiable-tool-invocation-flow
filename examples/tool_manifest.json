{
  "tool_id": "demo_metadata_lookup",
  "tool_name": "Demo Metadata Lookup Tool",
  "tool_version": "0.1.0",
  "description": "Returns deterministic metadata for the single supported demo dataset.",
  "allowed_operations": [
    "metadata.lookup"
  ],
  "input_schema": {
    "type": "object",
    "required": [
      "resource_id",
      "metadata_fields"
    ],
    "properties": {
      "resource_id": {
        "type": "string"
      },
      "metadata_fields": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "output_schema": {
    "type": "object",
    "required": [
      "resource_id",
      "metadata",
      "access_type"
    ],
    "properties": {
      "resource_id": {
        "type": "string"
      },
      "metadata": {
        "type": "object"
      },
      "access_type": {
        "type": "string"
      }
    }
  }
}
